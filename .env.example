# Server
PORT=3000
NODE_ENV=development
NODE_TLS_REJECT_UNAUTHORIZED=0

# Database
DATABASE_URL="mysql://yourusername:yourpassword@localhost:3306/zentaku"
DATABASE_USER="root"
DATABASE_PASSWORD="password"
DATABASE_NAME="zentaku"
DATABASE_HOST="localhost"
DATABASE_PORT=3306

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_characters
JWT_REFRESH_EXPIRES_IN=7d

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
BACKEND_EMAIL_VERIFICATION_URL=http://localhost:5173/verify-email?token=
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=MyAniList <noreply@myanilist.com>

# URLs
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
EMAIL_VERIFICATION_URL=${FRONTEND_URL}/verify-email
PASSWORD_RESET_URL=${FRONTEND_URL}/reset-password

# Streaming provider (AniProvider)
ANIPROVIDER_BASE_URL=http://localhost:8000
ANIPROVIDER_API_KEY=
ANIPROVIDER_AUTH_MODE=X-API-Key
ANIPROVIDER_TIMEOUT=25000

# Security
BCRYPT_ROUNDS=12

# OAuth (for future)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback

# MongoDB
MONGODB_URI=mongodb://localhost:27017/zentaku

# FilmServer (local HLS provider)
FILMSERVER_BASE_URL=http://localhost:3636
FILMSERVER_ANIME_IDS=108941,178022