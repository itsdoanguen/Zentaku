# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="mysql://user:password@localhost:3306/myanilist"

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_characters
JWT_REFRESH_EXPIRES_IN=7d

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=MyAniList <noreply@myanilist.com>

# URLs
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
EMAIL_VERIFICATION_URL=${FRONTEND_URL}/verify-email
PASSWORD_RESET_URL=${FRONTEND_URL}/reset-password

# Security
BCRYPT_ROUNDS=12

# OAuth (for future)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback